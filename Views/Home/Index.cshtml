@model IEnumerable<WebBanHang.Models.Product>
@{
    ViewData["Title"] = "Trang chủ";
    var searchQuery = ViewBag.SearchQuery as string ?? "";
}

<!-- ===== THANH TÌM KIẾM ===== -->
<div class="search-bar mb-3">
    <form method="get" asp-action="Index" class="d-flex">
        <input type="text" name="search" class="form-control" placeholder="Tìm sản phẩm..." value="@searchQuery" />
        <button type="submit" class="btn btn-primary ms-2">Tìm</button>
    </form>
</div>

<!-- ===== CAROUSEL ===== -->
<div id="heroCarousel" class="carousel slide mb-3" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
    </div>
    <div class="carousel-inner">
        <div class="carousel-item active">
            <div class="hero-placeholder hp1">
                <div class="text-wrap">
                    <div class="badge-sale">-37%</div>
                    <h2>THỊT CÁ TƯƠI NGON<br>GIÁ RẺ MỖI NGÀY</h2>
                </div>
            </div>
        </div>
        <div class="carousel-item">
            <div class="hero-placeholder hp2">
                <div class="text-wrap">
                    <div class="badge-sale">FLASH SALE</div>
                    <h2>GIÁ SỐC CUỐI TUẦN<br>GIẢM ĐẾN 49%</h2>
                </div>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<!-- ===== FLASH SALE ===== -->
//    1 _ Rau  (CatoriesID)
//    2 _ Thịt 
//    3_ Trái Cây
//    4_ Hải Sản
//    5_ Đồ Uống
//    6_ Bánh Kẹo
<div class="flash-sale-bar d-flex align-items-center gap-3 mb-3">
    <div class="flash-label text-center">FLASH<br><span>SALE</span></div>
    <div class="flash-scroll flex-grow-1 d-flex gap-3 overflow-auto">
        <div class="flash-item text-center">
            <div class="flash-item-img">🧴<span class="flash-item-badge">-35%</span></div>
            <div class="flash-item-name">Giặt xả</div>
        </div>
        <div class="flash-item text-center">
            <div class="flash-item-img">🍺<span class="flash-item-badge">-20%</span></div>
            <div class="flash-item-name">Bia</div>
        </div>
        <a asp-action="Index" asp-route-categoryId="1" class="text-decoration-none text-dark">
            <div class="flash-item text-center">
                <div class="flash-item-img">🥬<span class="flash-item-badge">-28%</span></div>
                <div class="flash-item-name">Rau xanh</div>
            </div>
        </a>
        <a asp-action="Index" asp-route-categoryId="2" class="text-decoration-none text-dark">
            <div class="flash-item text-center">
                <div class="flash-item-img">🥩<span class="flash-item-badge">-15%</span></div>
                <div class="flash-item-name">Thịt tươi</div>
            </div>
        </a>
        <a asp-action="Index" asp-route-categoryId="3" class="text-decoration-none text-dark">
            <div class="flash-item text-center">
                <div class="flash-item-img">🍎<span class="flash-item-badge">-10%</span></div>
                <div class="flash-item-name">Trái cây</div>
            </div>
        </a>

        <a asp-action="Index" asp-route-categoryId="4" class="text-decoration-none text-dark">
            <div class="flash-item text-center">
                <div class="flash-item-img">🦐<span class="flash-item-badge">-5%</span></div>
                <div class="flash-item-name">Hải sản</div>
            </div>
        </a>

        <a asp-action="Index" asp-route-categoryId="5" class="text-decoration-none text-dark">
            <div class="flash-item text-center">
                <div class="flash-item-img">🥤<span class="flash-item-badge">Mới</span></div>
                <div class="flash-item-name">Đồ uống</div>
            </div>
        </a>

        <a asp-action="Index" asp-route-categoryId="6" class="text-decoration-none text-dark">
            <div class="flash-item text-center">
                <div class="flash-item-img">🍪<span class="flash-item-badge">Hot</span></div>
                <div class="flash-item-name">Bánh kẹo</div>
            </div>
        </a>
    </div>
</div>

<!-- ===== SẢN PHẨM NỔI BẬT ===== -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="section-title">SẢN PHẨM NỔI BẬT</div>
    <a href="#" class="view-all">Xem tất cả <i class="bi bi-chevron-right"></i></a>
</div>

@if (!string.IsNullOrWhiteSpace(searchQuery))
{
    <p>Kết quả tìm kiếm cho: <strong>@searchQuery</strong></p>
}

@if (Model != null && Model.Any())
{
    <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-xl-5 g-2 mb-4">
        @foreach (var p in Model)
        {
            <div class="col fade-in">
                <div class="product-card">
                    <div class="product-img-wrap">
                        @if (!string.IsNullOrEmpty(p.Image))
                        {
                            <img src="@p.Image" alt="@p.Name" />
                        }
                        else
                        {
                            <span>🛒</span>
                        }
                    </div>
                    <div class="product-body">
                        <div class="product-name">@p.Name</div>
                        <div class="d-flex align-items-center justify-content-between mt-1">
                            <span class="product-price-new">@p.Price.ToString("N0")₫</span>
                            <button class="btn-add-cart" data-id="@p.Id"><i class="bi bi-plus"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state text-center">
        <i class="bi bi-box-seam" style="font-size: 3rem;"></i>
        <p>Không tìm thấy sản phẩm!</p>
    </div>
}