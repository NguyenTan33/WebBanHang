@model WebBanHang.Models.Cart

<div class="container py-5">
    <h2 class="fw-bold mb-4 text-dark">
        <i class="bi bi-cart3 text-success me-2"></i>Giỏ hàng của bạn
    </h2>

    @if (Model != null && Model.CartItems != null && Model.CartItems.Any())
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-0">
                        <table class="table align-middle mb-0">
                            <thead class="bg-light">
                                <tr class="text-muted small text-uppercase">
                                    <th class="ps-4">Sản phẩm</th>
                                    <th class="text-center">Giá</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end pe-4">Tổng</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.CartItems)
                                {
                                    <tr class="border-bottom">
                                        <td class="ps-4 py-3">
                                            <div class="d-flex align-items-center">
                                                <img src="https://pvmarthanoi.com.vn/wp-content/uploads/2023/01/thung-30-goi-mi-3-mien-gold-tom-chua-cay-dac-biet-75g-202211181207032573-500x600.jpg"
                                                     onerror="this.onerror=null;this.src='https://placehold.co/400x300?text=No+Image';"
                                                     style="width: 100%; height: 200px; object-fit: cover;" />

                                                <div>
                                                    <div class="fw-semibold">@item.Product.Name</div>
                                                    <div class="text-muted small">Mã SP: @item.Product.Id</div>

                                                    @* Nút Xóa *@
                                                    <form asp-controller="Cart" asp-action="RemoveItem" method="post" class="mt-1">
                                                        <input type="hidden" name="cartItemId" value="@item.Id" />
                                                        <button type="submit" class="btn btn-link text-danger p-0 small text-decoration-none">
                                                            <i class="bi bi-trash"></i> Xóa
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </td>

                                        <td class="text-center text-muted">
                                            @item.Product.Price.ToString("N0") đ
                                        </td>

                                        <td class="text-center">
                                            <div class="d-inline-flex align-items-center border rounded-pill px-2">
                                                @* Nút Giảm *@
                                                <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="m-0">
                                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                                    <input type="hidden" name="amount" value="-1" />
                                                    <button type="submit" class="btn btn-sm text-dark">-</button>
                                                </form>

                                                <span class="px-2 fw-bold">@item.Quantity</span>

                                                @* Nút Tăng *@
                                                <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="m-0">
                                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                                    <input type="hidden" name="amount" value="1" />
                                                    <button type="submit" class="btn btn-sm text-dark">+</button>
                                                </form>
                                            </div>
                                        </td>

                                        <td class="text-end pe-4 fw-bold text-danger">
                                            @((item.Product.Price * item.Quantity).ToString("N0")) đ
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <a asp-controller="Home" asp-action="Index" class="btn btn-link mt-3 text-decoration-none text-success fw-bold">
                    <i class="bi bi-arrow-left"></i> Tiếp tục mua thêm đồ
                </a>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <h5 class="fw-bold mb-4">Tóm tắt đơn hàng</h5>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Tạm tính</span>
                        <span class="fw-bold">@Model.CartItems.Sum(x => x.Product.Price * x.Quantity).ToString("N0") đ</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-4">
                        <span class="fw-bold fs-5">Tổng cộng</span>
                        <span class="fw-bold fs-4 text-danger">@Model.CartItems.Sum(x => x.Product.Price * x.Quantity).ToString("N0") đ</span>
                    </div>

                    <a asp-controller="Cart" asp-action="ConfirmOrder" class="btn btn-success w-100 py-3 rounded-pill fw-bold shadow">
                        THANH TOÁN NGAY
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        @* TRƯỜNG HỢP GIỎ HÀNG TRỐNG *@
        <div class="text-center py-5 shadow-sm bg-white rounded-4">
            <i class="bi bi-cart-x text-muted" style="font-size: 80px;"></i>
            <h4 class="fw-bold mt-3">Hiện không có gì trong giỏ hàng của bạn</h4>
            <p class="text-muted">Đừng để giỏ hàng cô đơn, hãy lấp đầy nó bằng đồ ăn ngon!</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-success px-5 py-2 rounded-pill fw-bold mt-2">
                QUAY VỀ TRANG CHỦ MUA ĐỒ
            </a>
        </div>
    }
</div>