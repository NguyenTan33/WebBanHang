        <script>
            // Cart interaction
            document.querySelectorAll('.btn-add-cart').forEach(btn => {
              btn.addEventListener('click', function(e) {
                e.stopPropagation();
                const badge = document.querySelector('.cart-badge');
                let count = parseInt(badge.textContent) || 0;
                badge.textContent = count + 1;
                this.style.transform = 'scale(1.4)';
                this.style.background = 'var(--green-dark)';
                setTimeout(() => {
                  this.style.transform = '';
                  this.style.background = '';
                }, 250);
              });
            });

            // Flash item click highlight
            document.querySelectorAll('.flash-item').forEach(item => {
              item.addEventListener('click', function() {
                this.querySelector('.flash-item-img').style.boxShadow = '0 0 0 3px var(--green-accent)';
                setTimeout(() => this.querySelector('.flash-item-img').style.boxShadow = '', 600);
              });
            });
        </script>
    </body>
    </html>

}

