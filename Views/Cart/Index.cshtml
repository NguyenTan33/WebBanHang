@model WebBanHang.Models.Cart
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
            body {
                background-color: #f0f2f0;
            }

            .cart-box {
                background: #fff;
                border-radius: 12px;
                padding: 20px;
                margin-bottom: 20px;
            }

            .product-img {
                width: 90px;
                height: 90px;
                object-fit: cover;
                border-radius: 10px;
            }

            .qty-box {
                border: 1px solid #ccc;
                border-radius: 20px;
                padding: 4px 10px;
                display: inline-flex;
                align-items: center;
            }

                .qty-box button {
                    border: none;
                    background: none;
                    font-weight: bold;
                    font-size: 16px;
                }

            .total {
                color: red;
                font-weight: bold;
            }
    </style>
</head>
<body>

    <div class="container py-5">

        <h3 class="mb-4"><i class="bi bi-cart3 text-success"></i> Giỏ hàng</h3>

        @if (Model != null && Model.CartItems != null && Model.CartItems.Any())
        {
            <div class="row g-4">
                <!-- Danh sách sản phẩm -->
                <div class="col-lg-8">
                    <div class="cart-box">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th class="text-center">Giá</th>
                                    <th class="text-center">SL</th>
                                    <th class="text-end">Tổng</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.CartItems)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <img class="product-img"
                                                     src="https://placehold.co/100x100"
                                                     onerror="this.onerror=null;this.src='https://placehold.co/100x100?text=No+Image';" />
                                                <div>
                                                    <div>@item.Product.Name</div>
                                                    <small class="text-muted">ID: @item.Product.Id</small>
                                                </div>
                                            </div>
                                        </td>

                                        <td class="text-center">@item.Product.Price.ToString("N0") đ</td>

                                        <td class="text-center">
                                            <div class="qty-box">
                                                <!-- Giảm số lượng -->
                                                <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="m-0">
                                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                                    <input type="hidden" name="amount" value="-1" />
                                                    <button>-</button>
                                                </form>

                                                <span class="px-2">@item.Quantity</span>

                                                <!-- Tăng số lượng -->
                                                <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="m-0">
                                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                                    <input type="hidden" name="amount" value="1" />
                                                    <button>+</button>
                                                </form>
                                            </div>
                                        </td>

                                        <td class="text-end total">
                                            @((item.Product.Price * item.Quantity).ToString("N0")) đ
                                        </td>

                                        <!-- Xóa sản phẩm -->
                                        <td class="text-end">
                                            <form asp-controller="Cart" asp-action="RemoveItem" method="post" class="d-inline">
                                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                                <button type="submit" class="btn btn-link text-danger p-0">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <!-- Nút tiếp tục mua sắm -->
                        <div class="d-flex gap-2 mt-3">
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-success flex-fill">
                                <i class="bi bi-arrow-left"></i> Tiếp tục mua sắm
                            </a>

                            <form asp-controller="Cart" asp-action="ClearCart" method="post" class="flex-fill m-0">
                                <button type="submit" class="btn btn-outline-danger w-100">
                                    Xóa toàn bộ giỏ hàng
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Tóm tắt đơn hàng -->
                <div class="col-lg-4">
                    <div class="cart-box">
                        <h5>Tóm tắt đơn hàng</h5>
                        <hr />
                        <div class="d-flex justify-content-between">
                            <span>Tạm tính:</span>
                            <span>@Model.CartItems.Sum(x => x.Product.Price * x.Quantity).ToString("N0") đ</span>
                        </div>
                        <div class="d-flex justify-content-between mt-2 mb-3">
                            <span class="fw-bold fs-5">Tổng cộng:</span>
                            <span class="total fs-5">@Model.CartItems.Sum(x => x.Product.Price * x.Quantity).ToString("N0") đ</span>
                        </div>
                        <a asp-controller="Cart" asp-action="ConfirmOrder" class="btn btn-success w-100 py-2">
                            Thanh toán ngay
                        </a>
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- Giỏ hàng trống -->
            <div class="text-center py-5">
                <i class="bi bi-cart-x" style="font-size: 70px; color: #ccc;"></i>
                <h4 class="mt-3">Giỏ hàng của bạn đang trống</h4>
                <p class="text-muted">Hãy thêm sản phẩm để tiếp tục mua sắm</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-success px-4 py-2 mt-3">
                    <i class="bi bi-arrow-left"></i> Mua sắm ngay
                </a>
            </div>
        }
    </div>

</body>
</html>