@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký – Bách Hóa Xanh</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
        :root {
            --green-dark: #1a7a2e;
            --green-main: #2c9e47;
            --green-light: #e8f7ec;
            --green-accent: #38b558;
            --yellow: #ffd600;
            --radius: 14px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Be Vietnam Pro', sans-serif;
            background: linear-gradient(135deg, #e8f7ec 0%, #f0f2f0 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* TOP BAR */
        .top-bar {
            background: var(--green-dark);
            padding: 7px 0;
            font-size: 12px;
            color: rgba(255,255,255,.75);
            text-align: center;
        }

            .top-bar a {
                color: rgba(255,255,255,.85);
                text-decoration: none;
            }

                .top-bar a:hover {
                    color: var(--yellow);
                }

        /* MINI HEADER */
        .mini-header {
            background: var(--green-main);
            padding: 12px 0;
            box-shadow: 0 2px 12px rgba(44,158,71,.25);
        }

            .mini-header .inner {
                max-width: 1200px;
                margin: 0 auto;
                padding: 0 24px;
                display: flex;
                align-items: center;
                justify-content: space-between;
            }

        .brand {
            text-decoration: none;
        }

        .brand-name {
            font-size: 22px;
            font-weight: 900;
            color: #fff;
            line-height: 1;
        }

            .brand-name span {
                color: var(--yellow);
            }

        .brand-tag {
            font-size: 10px;
            color: rgba(255,255,255,.75);
            font-style: italic;
        }

        .header-back {
            color: rgba(255,255,255,.85);
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 5px;
            transition: color .2s;
        }

            .header-back:hover {
                color: var(--yellow);
            }

        /* MAIN */
        .page-main {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 36px 16px;
        }

        /* CARD */
        .auth-card {
            background: #fff;
            border-radius: var(--radius);
            box-shadow: 0 8px 40px rgba(26,122,46,.13);
            overflow: hidden;
            width: 100%;
            max-width: 960px;
            display: flex;
            min-height: 580px;
        }

        /* LEFT PANEL */
        .card-left {
            background: linear-gradient(160deg, var(--green-dark) 0%, var(--green-main) 55%, var(--green-accent) 100%);
            flex: 0 0 36%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 44px 32px;
            color: #fff;
            position: relative;
            overflow: hidden;
        }

            .card-left::before {
                content: '';
                position: absolute;
                width: 260px;
                height: 260px;
                border-radius: 50%;
                background: rgba(255,255,255,.07);
                top: -80px;
                right: -80px;
            }

            .card-left::after {
                content: '';
                position: absolute;
                width: 200px;
                height: 200px;
                border-radius: 50%;
                background: rgba(255,255,255,.06);
                bottom: -60px;
                left: -60px;
            }

        .left-brand {
            font-size: 28px;
            font-weight: 900;
            line-height: 1;
            margin-bottom: 5px;
            position: relative;
            z-index: 1;
        }

            .left-brand span {
                color: var(--yellow);
            }

        .left-tag {
            font-size: 12px;
            opacity: .8;
            font-style: italic;
            margin-bottom: 24px;
            position: relative;
            z-index: 1;
        }

        .left-section-title {
            font-size: 14px;
            font-weight: 800;
            opacity: .95;
            margin-bottom: 12px;
            position: relative;
            z-index: 1;
            align-self: flex-start;
            width: 100%;
        }

        .benefit-list {
            list-style: none;
            width: 100%;
            position: relative;
            z-index: 1;
        }

            .benefit-list li {
                display: flex;
                align-items: flex-start;
                gap: 12px;
                padding: 9px 0;
                border-bottom: 1px solid rgba(255,255,255,.13);
                font-size: 13px;
                font-weight: 500;
                line-height: 1.4;
            }

                .benefit-list li:last-child {
                    border-bottom: none;
                }

        .benefit-icon {
            width: 26px;
            height: 26px;
            background: rgba(255,255,255,.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            flex-shrink: 0;
            margin-top: 1px;
        }

        /* RIGHT PANEL */
        .card-right {
            flex: 1;
            padding: 40px 44px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .form-title {
            font-size: 24px;
            font-weight: 900;
            color: var(--green-dark);
            margin-bottom: 4px;
        }

        .form-sub {
            font-size: 13px;
            color: #888;
            margin-bottom: 22px;
        }

        /* Inputs */
        .form-floating .form-control {
            border: 1.5px solid #e0e0e0;
            border-radius: 10px !important;
            font-size: 14px;
            font-family: 'Be Vietnam Pro', sans-serif;
            transition: border-color .2s, box-shadow .2s;
        }

            .form-floating .form-control:focus {
                border-color: var(--green-main);
                box-shadow: 0 0 0 3px rgba(44,158,71,.12);
            }

        .form-floating label {
            font-size: 13px;
            color: #999;
        }

        /* Password hint */
        .pw-hint {
            font-size: 11.5px;
            color: #bbb;
            margin-top: -8px;
            margin-bottom: 12px;
            padding-left: 4px;
        }

            .pw-hint i {
                color: var(--green-main);
            }

        /* Submit */
        .btn-submit {
            background: linear-gradient(135deg, var(--green-main), var(--green-accent));
            border: none;
            border-radius: 25px;
            padding: 12px;
            width: 100%;
            font-size: 15px;
            font-weight: 800;
            color: #fff;
            cursor: pointer;
            letter-spacing: .2px;
            font-family: 'Be Vietnam Pro', sans-serif;
            transition: transform .15s, box-shadow .2s;
            box-shadow: 0 4px 16px rgba(44,158,71,.3);
        }

            .btn-submit:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 22px rgba(44,158,71,.4);
            }

            .btn-submit:active {
                transform: translateY(0);
            }

        /* Terms note */
        .terms-note {
            font-size: 11.5px;
            color: #bbb;
            text-align: center;
            margin-top: 8px;
            line-height: 1.5;
        }

            .terms-note a {
                color: var(--green-main);
                text-decoration: none;
            }

                .terms-note a:hover {
                    text-decoration: underline;
                }

        /* Divider */
        .or-divider {
            display: flex;
            align-items: center;
            gap: 12px;
            color: #ccc;
            font-size: 12px;
            margin: 14px 0;
        }

            .or-divider::before, .or-divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: #eee;
            }

        /* External */
        .btn-ext {
            border: 1.5px solid #e0e0e0;
            border-radius: 10px;
            background: #fff;
            color: #333;
            font-size: 13px;
            font-weight: 600;
            padding: 9px 18px;
            cursor: pointer;
            transition: border-color .2s, background .2s;
            font-family: 'Be Vietnam Pro', sans-serif;
        }

            .btn-ext:hover {
                border-color: var(--green-main);
                background: var(--green-light);
                color: var(--green-dark);
            }

        .no-ext {
            font-size: 13px;
            color: #bbb;
            background: #f8f8f8;
            border-radius: 10px;
            padding: 12px 14px;
            line-height: 1.6;
        }

            .no-ext a {
                color: var(--green-main);
            }

        /* Login banner */
        .login-banner {
            background: var(--green-light);
            border-radius: 10px;
            padding: 11px 16px;
            font-size: 13px;
            color: #333;
            margin-top: 14px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }

            .login-banner a {
                border: 1.5px solid var(--green-main);
                color: var(--green-main);
                border-radius: 20px;
                padding: 5px 16px;
                font-size: 12px;
                font-weight: 700;
                text-decoration: none;
                white-space: nowrap;
                transition: background .2s, color .2s;
            }

                .login-banner a:hover {
                    background: var(--green-main);
                    color: #fff;
                }

        /* FOOTER */
        .mini-footer {
            background: var(--green-dark);
            color: rgba(255,255,255,.5);
            font-size: 12px;
            text-align: center;
            padding: 14px 0;
        }

            .mini-footer a {
                color: rgba(255,255,255,.65);
                text-decoration: none;
            }

                .mini-footer a:hover {
                    color: var(--yellow);
                }

        @@media (max-width: 767px) {
            .card-left {
                display: none;
            }

            .card-right {
                padding: 32px 24px;
            }

            .auth-card {
                max-width: 440px;
            }
        }
    </style>
</head>
<body>

    <!-- TOP BAR -->
    <div class="top-bar">
        <i class="bi bi-telephone-fill me-1"></i> Hotline: <a href="#">1800 6936</a>
        &nbsp;|&nbsp; Giao hàng nhanh trong 2 giờ &nbsp;|&nbsp;
        <a href="#">Hệ thống cửa hàng</a>
    </div>

    <!-- MINI HEADER -->
    <div class="mini-header">
        <div class="inner">
            <a href="/" class="brand">
                <div class="brand-name">Bách hóa <span>XANH</span></div>
                <div class="brand-tag">Siêu thị gần nhà, giá tiết kiệm</div>
            </a>
            <a href="/" class="header-back">
                <i class="bi bi-arrow-left"></i> Quay về trang chủ
            </a>
        </div>
    </div>

    <!-- MAIN -->
    <main class="page-main">
        <div class="auth-card">

            <!-- LEFT -->
            <div class="card-left">
                <div class="left-brand">Bách hóa <span>XANH</span></div>
                <div class="left-tag">Siêu thị gần nhà, giá tiết kiệm</div>
                <div class="left-section-title">🎉 Quyền lợi thành viên</div>
                <ul class="benefit-list">
                    <li>
                        <span class="benefit-icon"><i class="bi bi-tag-fill"></i></span>
                        <span>Nhận ngay <strong>voucher 50.000₫</strong> cho đơn hàng đầu tiên</span>
                    </li>
                    <li>
                        <span class="benefit-icon"><i class="bi bi-star-fill"></i></span>
                        <span>Tích điểm mỗi đơn hàng, đổi quà hấp dẫn</span>
                    </li>
                    <li>
                        <span class="benefit-icon"><i class="bi bi-bell-fill"></i></span>
                        <span>Nhận thông báo Flash Sale sớm nhất</span>
                    </li>
                    <li>
                        <span class="benefit-icon"><i class="bi bi-truck"></i></span>
                        <span>Ưu tiên giao hàng nhanh trong 2 giờ</span>
                    </li>
                    <li>
                        <span class="benefit-icon"><i class="bi bi-heart-fill"></i></span>
                        <span>Lưu danh sách yêu thích, mua lại dễ dàng</span>
                    </li>
                </ul>
            </div>

            <!-- RIGHT -->
            <div class="card-right">
                <div class="form-title">Tạo tài khoản</div>
                <div class="form-sub">Đăng ký miễn phí – nhận ngay ưu đãi dành riêng cho thành viên mới!</div>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert" style="font-size:13px;"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control"
                               autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <label asp-for="Input.Email"><i class="bi bi-envelope me-1"></i>Email</label>
                        <span asp-validation-for="Input.Email" class="text-danger" style="font-size:12px;"></span>
                    </div>

                    <div class="form-floating mb-1">
                        <input asp-for="Input.Password" class="form-control"
                               autocomplete="new-password" aria-required="true" placeholder="Mật khẩu" />
                        <label asp-for="Input.Password"><i class="bi bi-lock me-1"></i>Mật khẩu</label>
                        <span asp-validation-for="Input.Password" class="text-danger" style="font-size:12px;"></span>
                    </div>
                    <div class="pw-hint"><i class="bi bi-info-circle"></i> Tối thiểu 6 ký tự, gồm chữ hoa, số và ký tự đặc biệt</div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.ConfirmPassword" class="form-control"
                               autocomplete="new-password" aria-required="true" placeholder="Xác nhận mật khẩu" />
                        <label asp-for="Input.ConfirmPassword"><i class="bi bi-lock-fill me-1"></i>Xác nhận mật khẩu</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger" style="font-size:12px;"></span>
                    </div>

                    <button id="registerSubmit" type="submit" class="btn-submit mb-1">
                        <i class="bi bi-person-plus-fill me-2"></i>Đăng ký ngay
                    </button>
                    <div class="terms-note">
                        Bằng cách đăng ký, bạn đồng ý với
                        <a href="#">Điều khoản dịch vụ</a> và <a href="#">Chính sách bảo mật</a>.
                    </div>

                    @{
                        if ((Model.ExternalLogins?.Count ?? 0) > 0)
                        {
                            <div class="or-divider">hoặc đăng ký bằng</div>
                            <form id="external-account" asp-page="./ExternalLogin"
                                  asp-route-returnUrl="@Model.ReturnUrl" method="post"
                                  class="d-flex flex-wrap gap-2">
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <button type="submit" class="btn-ext flex-fill"
                                            name="provider" value="@provider.Name">
                                        @provider.DisplayName
                                    </button>
                                }
                            </form>
                        }
                        else
                        {
                            <div class="or-divider">đăng ký bên thứ ba</div>
                            <div class="no-ext">
                                Chưa có dịch vụ xác thực ngoài nào được cấu hình.
                                <a href="https://go.microsoft.com/fwlink/?LinkID=532715" target="_blank">Tìm hiểu thêm</a>
                            </div>
                        }
                    }
                </form>

                <div class="login-banner">
                    <span>Đã có tài khoản?</span>
                    <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Đăng nhập</a>
                </div>
            </div>

        </div>
    </main>

    <!-- MINI FOOTER -->
    <footer class="mini-footer">
        © 2026 Bách Hóa Xanh &nbsp;·&nbsp;
        <a asp-area="" asp-controller="Home" asp-action="Privacy">Chính sách bảo mật</a>
        &nbsp;·&nbsp; <a href="#">Điều khoản dịch vụ</a>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
