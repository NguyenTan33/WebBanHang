@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập – Thắng Hóa Xanh</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
        :root {
            --green-dark: #1a7a2e;
            --green-main: #2c9e47;
            --green-light: #e8f7ec;
            --green-accent: #38b558;
            --yellow: #ffd600;
            --radius: 14px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Be Vietnam Pro', sans-serif;
            background: linear-gradient(135deg, #e8f7ec 0%, #f0f2f0 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* TOP BAR */
        .top-bar {
            background: var(--green-dark);
            padding: 7px 0;
            font-size: 12px;
            color: rgba(255,255,255,.75);
            text-align: center;
        }

            .top-bar a {
                color: rgba(255,255,255,.85);
                text-decoration: none;
            }

                .top-bar a:hover {
                    color: var(--yellow);
                }

        /* MINI HEADER */
        .mini-header {
            background: var(--green-main);
            padding: 12px 0;
            box-shadow: 0 2px 12px rgba(44,158,71,.25);
        }

            .mini-header .inner {
                max-width: 1200px;
                margin: 0 auto;
                padding: 0 24px;
                display: flex;
                align-items: center;
                justify-content: space-between;
            }

        .brand {
            text-decoration: none;
        }

        .brand-name {
            font-size: 22px;
            font-weight: 900;
            color: #fff;
            line-height: 1;
        }

            .brand-name span {
                color: var(--yellow);
            }

        .brand-tag {
            font-size: 10px;
            color: rgba(255,255,255,.75);
            font-style: italic;
        }

        .header-back {
            color: rgba(255,255,255,.85);
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 5px;
            transition: color .2s;
        }

            .header-back:hover {
                color: var(--yellow);
            }

        /* MAIN */
        .page-main {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 36px 16px;
        }

        /* CARD */
        .auth-card {
            background: #fff;
            border-radius: var(--radius);
            box-shadow: 0 8px 40px rgba(26,122,46,.13);
            overflow: hidden;
            width: 100%;
            max-width: 920px;
            display: flex;
            min-height: 530px;
        }

        /* LEFT PANEL */
        .card-left {
            background: linear-gradient(160deg, var(--green-dark) 0%, var(--green-main) 55%, var(--green-accent) 100%);
            flex: 0 0 38%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 44px 32px;
            color: #fff;
            position: relative;
            overflow: hidden;
        }

            .card-left::before {
                content: '';
                position: absolute;
                width: 260px;
                height: 260px;
                border-radius: 50%;
                background: rgba(255,255,255,.07);
                top: -80px;
                right: -80px;
            }

            .card-left::after {
                content: '';
                position: absolute;
                width: 180px;
                height: 180px;
                border-radius: 50%;
                background: rgba(255,255,255,.06);
                bottom: -50px;
                left: -50px;
            }

        .left-brand {
            font-size: 28px;
            font-weight: 900;
            line-height: 1;
            margin-bottom: 5px;
            position: relative;
            z-index: 1;
        }

            .left-brand span {
                color: var(--yellow);
            }

        .left-tag {
            font-size: 12px;
            opacity: .8;
            font-style: italic;
            margin-bottom: 30px;
            position: relative;
            z-index: 1;
        }

        .perk-list {
            list-style: none;
            width: 100%;
            position: relative;
            z-index: 1;
        }

            .perk-list li {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 9px 0;
                border-bottom: 1px solid rgba(255,255,255,.13);
                font-size: 13px;
                font-weight: 500;
            }

                .perk-list li:last-child {
                    border-bottom: none;
                }

        .perk-icon {
            width: 28px;
            height: 28px;
            background: rgba(255,255,255,.18);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            flex-shrink: 0;
        }

        /* RIGHT PANEL */
        .card-right {
            flex: 1;
            padding: 44px 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .form-title {
            font-size: 24px;
            font-weight: 900;
            color: var(--green-dark);
            margin-bottom: 4px;
        }

        .form-sub {
            font-size: 13px;
            color: #888;
            margin-bottom: 26px;
        }

        /* Inputs */
        .form-floating .form-control {
            border: 1.5px solid #e0e0e0;
            border-radius: 10px !important;
            font-size: 14px;
            font-family: 'Be Vietnam Pro', sans-serif;
            transition: border-color .2s, box-shadow .2s;
        }

            .form-floating .form-control:focus {
                border-color: var(--green-main);
                box-shadow: 0 0 0 3px rgba(44,158,71,.12);
            }

        .form-floating label {
            font-size: 13px;
            color: #999;
        }

        /* Extra row */
        .extra-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .remember-label {
            display: flex;
            align-items: center;
            gap: 7px;
            font-size: 13px;
            color: #555;
            cursor: pointer;
        }

            .remember-label input {
                width: 16px;
                height: 16px;
                accent-color: var(--green-main);
            }

        .forgot-link {
            font-size: 12.5px;
            color: var(--green-main);
            font-weight: 600;
            text-decoration: none;
        }

            .forgot-link:hover {
                color: var(--green-dark);
                text-decoration: underline;
            }

        /* Submit */
        .btn-submit {
            background: linear-gradient(135deg, var(--green-main), var(--green-accent));
            border: none;
            border-radius: 25px;
            padding: 12px;
            width: 100%;
            font-size: 15px;
            font-weight: 800;
            color: #fff;
            cursor: pointer;
            letter-spacing: .2px;
            font-family: 'Be Vietnam Pro', sans-serif;
            transition: transform .15s, box-shadow .2s;
            box-shadow: 0 4px 16px rgba(44,158,71,.3);
        }

            .btn-submit:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 22px rgba(44,158,71,.4);
            }

            .btn-submit:active {
                transform: translateY(0);
            }

        /* Divider */
        .or-divider {
            display: flex;
            align-items: center;
            gap: 12px;
            color: #ccc;
            font-size: 12px;
            margin: 16px 0;
        }

            .or-divider::before, .or-divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: #eee;
            }

        /* External */
        .btn-ext {
            border: 1.5px solid #e0e0e0;
            border-radius: 10px;
            background: #fff;
            color: #333;
            font-size: 13px;
            font-weight: 600;
            padding: 9px 18px;
            cursor: pointer;
            transition: border-color .2s, background .2s;
            font-family: 'Be Vietnam Pro', sans-serif;
        }

            .btn-ext:hover {
                border-color: var(--green-main);
                background: var(--green-light);
                color: var(--green-dark);
            }

        .no-ext {
            font-size: 13px;
            color: #bbb;
            background: #f8f8f8;
            border-radius: 10px;
            padding: 12px 14px;
            line-height: 1.6;
        }

            .no-ext a {
                color: var(--green-main);
            }

        /* Helper links */
        .helper-links {
            display: flex;
            flex-wrap: wrap;
            gap: 4px 14px;
            margin-top: 12px;
        }

            .helper-links a {
                font-size: 12px;
                color: var(--green-main);
                font-weight: 600;
                text-decoration: none;
            }

                .helper-links a:hover {
                    text-decoration: underline;
                }

        /* Register banner */
        .reg-banner {
            background: var(--green-light);
            border-radius: 10px;
            padding: 11px 16px;
            font-size: 13px;
            color: #333;
            margin-top: 14px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }

            .reg-banner a {
                background: var(--green-main);
                color: #fff;
                border-radius: 20px;
                padding: 5px 16px;
                font-size: 12px;
                font-weight: 700;
                text-decoration: none;
                white-space: nowrap;
                transition: background .2s;
            }

                .reg-banner a:hover {
                    background: var(--green-dark);
                }

        /* FOOTER */
        .mini-footer {
            background: var(--green-dark);
            color: rgba(255,255,255,.5);
            font-size: 12px;
            text-align: center;
            padding: 14px 0;
        }

            .mini-footer a {
                color: rgba(255,255,255,.65);
                text-decoration: none;
            }

                .mini-footer a:hover {
                    color: var(--yellow);
                }

        @@media (max-width: 767px) {
            .card-left {
                display: none;
            }

            .card-right {
                padding: 32px 24px;
            }

            .auth-card {
                max-width: 440px;
            }
        }
    </style>
</head>
<body>

    <!-- TOP BAR -->
    <div class="top-bar">
        <i class="bi bi-telephone-fill me-1"></i> Hotline: <a href="#">1800 6936</a>
        &nbsp;|&nbsp; Giao hàng nhanh trong 2 giờ &nbsp;|&nbsp;
        <a href="#">Hệ thống cửa hàng</a>
    </div>

    <!-- MINI HEADER -->
    <div class="mini-header">
        <div class="inner">
            <a href="/" class="brand">
                <div class="brand-name">Bách hóa <span>XANH</span></div>
                <div class="brand-tag">Siêu thị gần nhà, giá tiết kiệm</div>
            </a>
            <a href="/" class="header-back">
                <i class="bi bi-arrow-left"></i> Quay về trang chủ
            </a>
        </div>
    </div>

    <!-- MAIN -->
    <main class="page-main">
        <div class="auth-card">

            <!-- LEFT -->
            <div class="card-left">
                <div class="left-brand">Bách hóa <span>XANH</span></div>
                <div class="left-tag">Siêu thị gần nhà, giá tiết kiệm</div>
                <ul class="perk-list">
                    <li><span class="perk-icon"><i class="bi bi-truck"></i></span> Giao hàng nhanh trong 2 giờ</li>
                    <li><span class="perk-icon"><i class="bi bi-tag-fill"></i></span> Hàng ngàn ưu đãi mỗi ngày</li>
                    <li><span class="perk-icon"><i class="bi bi-gift-fill"></i></span> Tích điểm đổi quà hấp dẫn</li>
                    <li><span class="perk-icon"><i class="bi bi-shield-check-fill"></i></span> Thanh toán an toàn, bảo mật</li>
                    <li><span class="perk-icon"><i class="bi bi-arrow-repeat"></i></span> Đổi trả dễ dàng trong 7 ngày</li>
                </ul>
            </div>

            <!-- RIGHT -->
            <div class="card-right">
                <div class="form-title">Đăng nhập</div>
                <div class="form-sub">Chào mừng bạn quay lại! Vui lòng đăng nhập để tiếp tục.</div>

                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert" style="font-size:13px;"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control"
                               autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <label asp-for="Input.Email"><i class="bi bi-envelope me-1"></i>Email</label>
                        <span asp-validation-for="Input.Email" class="text-danger" style="font-size:12px;"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control"
                               autocomplete="current-password" aria-required="true" placeholder="Mật khẩu" />
                        <label asp-for="Input.Password"><i class="bi bi-lock me-1"></i>Mật khẩu</label>
                        <span asp-validation-for="Input.Password" class="text-danger" style="font-size:12px;"></span>
                    </div>

                    <div class="extra-row">
                        <label class="remember-label">
                            <input asp-for="Input.RememberMe" />
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                        <a class="forgot-link" asp-page="./ForgotPassword">Quên mật khẩu?</a>
                    </div>

                    <button id="login-submit" type="submit" class="btn-submit mb-3">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                    </button>

                    @{
                        if ((Model.ExternalLogins?.Count ?? 0) > 0)
                        {
                            <div class="or-divider">hoặc đăng nhập bằng</div>
                            <form id="external-account" asp-page="./ExternalLogin"
                                  asp-route-returnUrl="@Model.ReturnUrl" method="post"
                                  class="d-flex flex-wrap gap-2">
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <button type="submit" class="btn-ext flex-fill"
                                            name="provider" value="@provider.Name">
                                        @provider.DisplayName
                                    </button>
                                }
                            </form>
                        }
                        else
                        {
                            <div class="or-divider">đăng nhập bên thứ ba</div>
                            <div class="no-ext">
                                Chưa có dịch vụ xác thực ngoài nào được cấu hình.
                                <a href="https://go.microsoft.com/fwlink/?LinkID=532715" target="_blank">Tìm hiểu thêm</a>
                            </div>
                        }
                    }

                    <div class="helper-links">
                        <a asp-page="./ResendEmailConfirmation">
                            <i class="bi bi-envelope-check me-1"></i>Gửi lại email xác nhận
                        </a>
                    </div>
                </form>

                <div class="reg-banner">
                    <span>Chưa có tài khoản?</span>
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Đăng ký ngay</a>
                </div>
            </div>

        </div>
    </main>

    <!-- MINI FOOTER -->
    <footer class="mini-footer">
        © 2026 Bách Hóa Xanh &nbsp;·&nbsp;
        <a asp-area="" asp-controller="Home" asp-action="Privacy">Chính sách bảo mật</a>
        &nbsp;·&nbsp; <a href="#">Điều khoản dịch vụ</a>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
