@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Thanh toán thành công - Bách Hóa Xanh</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .success-card {
            background: white;
            padding: 3rem;
            border-radius: 2rem;
            box-shadow: 0 20px 40px rgba(0,0,0,0.05);
            max-width: 500px;
            width: 100%;
            text-align: center;
            border: none;
            /* Hiệu ứng hiện ra từ từ cho thầy lác mắt */
            animation: fadeInUp 0.6s ease-out;
        }

        .icon-box {
            width: 100px;
            height: 100px;
            background: #e8f5e9;
            color: #2e7d32;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 3.5rem;
        }

        .btn-success {
            background-color: #2e7d32;
            border: none;
            padding: 0.8rem 2.5rem;
            transition: all 0.3s ease;
        }

            .btn-success:hover {
                background-color: #1b5e20;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(46, 125, 50, 0.3);
            }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>

    <div class="success-card">
        <div class="icon-box shadow-sm">
            <i class="bi bi-check-lg"></i>
        </div>

        <h2 class="fw-bold text-dark mb-3">Đã Thanh Toán Thành Công!</h2>

        <p class="text-muted mb-4 px-3">
            Cảm ơn bạn đã ủng hộ **Bách Hóa Xanh**. <br>
            Đơn hàng đang chờ xác nhận, chuẩn bị nhận hàng nhé!
        </p>

        <div class="d-grid gap-2 col-10 mx-auto">
            <a href="/" class="btn btn-success rounded-pill fw-bold text-uppercase">
                Tiếp tục mua sắm
            </a>
            <a href="/Cart" class="btn btn-link text-muted text-decoration-none mt-2 small">
                Xem lại giỏ hàng
            </a>
        </div>
    </div>

</body>
</html>